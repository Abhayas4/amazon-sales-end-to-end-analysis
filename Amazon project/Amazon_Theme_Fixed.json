{
    "name": "Amazon Theme",
    "dataColors": [
        "#FF9900",
        "#232F3E",
        "#37475A",
        "#B0BEC5",
        "#90A4AE",
        "#D5DBDB"
    ],
    "background": "#F2F3F4",
    "foreground": "#232F3E",
    "tableAccent": "#FF9900",
    "visualStyles": {
